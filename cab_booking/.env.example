# --- Common Configuration ---
EUREKA_DEFAULT_ZONE=http://eureka-server:8761/eureka/
EUREKA_HOSTNAME=eureka-server
CONFIG_SERVER_URL=http://localhost:8888
SPRING_PROFILES_ACTIVE=native

# --- JWT Security (Certs) ---
# You need to generate these .pem files in your local certs folder
PUBLIC_KEY_PATH=classpath:certs/public_key.pem
PRIVATE_KEY_PATH=certs/private_key.pem

# --- Auth Service ---
AUTH_SERVICE_PORT=8081
AUTH_DB_NAME=auth_db
AUTH_DB_USER=your_db_user
AUTH_DB_PASSWORD=your_db_password
AUTH_DB_PORT=3307
AUTH_DB_JDBC_URL=jdbc:postgresql://auth-db:3307/auth_db

# --- API Gateway & Infrastructure ---
API_GATEWAY_PORT=8080
CONFIG_SERVER_PORT=8888
EUREKA_SERVER_PORT=8761

# --- Databases & Message Broker ---
MONGODB_URI=mongodb://mongodb:27017/notification_db
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- Custom Services ---
NOTIFICATION_SERVICE_PORT=8085
REVIEW_SERVICE_PORT=8086
