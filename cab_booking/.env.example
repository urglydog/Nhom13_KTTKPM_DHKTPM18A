# ===================================
# 1. INFRASTRUCTURE & COMMON CONFIG
# ===================================
EUREKA_DEFAULT_ZONE=http://your-eureka-host:8761/eureka/
EUREKA_HOSTNAME=your-eureka-host
EUREKA_SERVER_PORT=8761

CONFIG_SERVER_URL=http://your-config-server-host:8888
CONFIG_SERVER_PORT=8888

SPRING_PROFILES_ACTIVE=default
JWT_PRIVATE_KEY=your_base64_or_pem_private_key

# ===================================
# 2. MESSAGE BROKER & CACHING
# ===================================
KAFKA_BOOTSTRAP_SERVERS=your-kafka-host:9092
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
MONGODB_URI=mongodb://your-mongodb-host:27017/your_notification_db

# ===================================
# TIER 1: COMMUNICATION LAYER (GATEWAYS)
# ===================================

# API Gateway - Main entry point for Mobile App (Customers & Drivers)
API_GATEWAY_PORT=8080

# WebSocket Gateway - Real-time GPS & communication
WEBSOCKET_GATEWAY_PORT=8089

# ===================================
# TIER 2: CORE SERVICES LAYER
# ===================================

# Auth Service
AUTH_SERVICE_PORT=8081
AUTH_SERVICE_URL=http://your-auth-service-host:8081
AUTH_DB_NAME=your_auth_db_name
AUTH_DB_USER=your_auth_db_user
AUTH_DB_PASSWORD=your_auth_db_password
AUTH_DB_PORT=5433
AUTH_DB_JDBC_URL=jdbc:postgresql://your-auth-db-host:5432/your_auth_db_name
AUTH_ACCESS_TOKEN_MINUTES=120
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_REGISTRATION_OTP_MINUTES=10
AUTH_REGISTRATION_OTP_LENGTH=6
AUTH_PASSWORD_RESET_OTP_MINUTES=10
AUTH_PASSWORD_RESET_OTP_LENGTH=6

# User Service
USER_SERVICE_PORT=8082
USER_SERVICE_URL=http://your-user-service-host:8082
USER_DB_NAME=your_user_db_name
USER_DB_USER=your_user_db_user
USER_DB_PASSWORD=your_user_db_password
USER_DB_PORT=5434
USER_DB_JDBC_URL=jdbc:postgresql://your-user-db-host:5432/your_user_db_name

# Driver Service
DRIVER_SERVICE_PORT=8083
DRIVER_SERVICE_URL=http://your-driver-service-host:8083
DRIVER_DB_NAME=your_driver_db_name
DRIVER_DB_USER=your_driver_db_user
DRIVER_DB_PASSWORD=your_driver_db_password
DRIVER_DB_PORT=5435
DRIVER_DB_JDBC_URL=jdbc:postgresql://your-driver-db-host:5432/your_driver_db_name

# Booking Service
BOOKING_SERVICE_PORT=8084
BOOKING_SERVICE_URL=http://your-booking-service-host:8084
BOOKING_DB_NAME=your_booking_db_name
BOOKING_DB_USER=your_booking_db_user
BOOKING_DB_PASSWORD=your_booking_db_password
BOOKING_DB_PORT=5437
BOOKING_DB_JDBC_URL=jdbc:postgresql://your-booking-db-host:5432/your_booking_db_name

# Ride Service
RIDE_SERVICE_PORT=8085
RIDE_SERVICE_URL=http://your-ride-service-host:8085
RIDE_DB_NAME=your_ride_db_name
RIDE_DB_USER=your_ride_db_user
RIDE_DB_PASSWORD=your_ride_db_password
RIDE_DB_PORT=5436
RIDE_DB_JDBC_URL=jdbc:postgresql://ride-db:5432/your_ride_db_name

# ===================================
# TIER 3: SUPPORT & AI SERVICES
# ===================================

# Matching Service
MATCHING_SERVICE_PORT=8086
MATCHING_SERVICE_URL=http://your-matching-service-host:8086

# ETA Service
ETA_SERVICE_PORT=8087
ETA_SERVICE_URL=http://your-eta-service-host:8087

# Pricing Service
PRICING_SERVICE_PORT=8088
PRICING_SERVICE_URL=http://your-pricing-service-host:8088

# Payment Service
PAYMENT_SERVICE_PORT=8090
PAYMENT_SERVICE_URL=http://your-payment-service-host:8090
PAYMENT_DB_NAME=your_payment_db_name
PAYMENT_DB_USER=your_payment_db_user
PAYMENT_DB_PASSWORD=your_payment_db_password
PAYMENT_DB_PORT=5438
PAYMENT_DB_JDBC_URL=jdbc:postgresql://your-payment-db-host:5432/your_payment_db_name

# Review Service
REVIEW_SERVICE_PORT=8091
REVIEW_SERVICE_URL=http://your-review-service-host:8091

# Notification Service
NOTIFICATION_SERVICE_PORT=8092
NOTIFICATION_SERVICE_URL=http://your-notification-service-host:8092

# AI Scoring Service (Python/FastAPI)
AI_SCORING_SERVICE_PORT=8000
AI_SCORING_SERVICE_URL=http://your-ai-scoring-service-host:8000

# ===================================
# EXTERNAL SERVICES
# ===================================

# Email Service (via Brevo)
EMAIL_SERVICE_PORT=8087
EMAIL_SERVICE_URL=http://your-email-service-host:8087
BREVO_BASE_URL=https://api.brevo.com
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_sender_email@example.com
BREVO_SENDER_NAME=Your App Name

# ===================================
# 4. THIRD-PARTY PAYMENT GATEWAYS
# ===================================

# Public HTTPS base URL from ngrok that forwards to API Gateway port 8080.
PUBLIC_API_BASE_URL=https://your-ngrok-domain.ngrok-free.app

# MoMo Sandbox
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_NOTIFY_URL=https://your-ngrok-domain.ngrok-free.app/api/payments/momo/ipn
MOMO_RETURN_URL=https://your-ngrok-domain.ngrok-free.app/payment-result

# ZaloPay Sandbox
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2
ZALOPAY_APP_ID=your_zalopay_app_id
ZALOPAY_KEY1=your_zalopay_key1
ZALOPAY_KEY2=your_zalopay_key2
ZALOPAY_CALLBACK_URL=https://your-ngrok-domain.ngrok-free.app/api/payments/zalopay/callback
ZALOPAY_REDIRECT_URL=https://your-ngrok-domain.ngrok-free.app/payment-result

# VNPAY Sandbox
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_RETURN_URL=https://your-ngrok-domain.ngrok-free.app/api/payments/vnpay/return
VNPAY_IPN_URL=https://your-ngrok-domain.ngrok-free.app/api/payments/vnpay/ipn
VNPAY_VERSION=2.1.0
VNPAY_COMMAND=pay
VNPAY_CURR_CODE=VND
VNPAY_LOCALE=vn
VNPAY_ORDER_TYPE=other
VNPAY_BANK_CODE=NCB
VNPAY_DEFAULT_IP_ADDRESS=127.0.0.1
VNPAY_EXPIRE_MINUTES=15
