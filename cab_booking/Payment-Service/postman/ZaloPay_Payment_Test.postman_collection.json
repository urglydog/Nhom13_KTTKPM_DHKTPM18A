		{
			"name": "4. ZaloPay Callback (Webhook)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response status is 200', function() {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Callback response indicates success', function() {",
							"    const response = pm.response.json();",
							"    pm.expect(response.return_code).to.eq(1);",
							"    pm.expect(response.return_message).to.eq('Callback Received');",
							"});",
							"",
							"console.log('Callback response:', pm.response.json());"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// This script generates a valid ZaloPay callback for sandbox testing",
							"// In production, ZaloPay server will send this callback automatically",
							"",
							"const appId = 2553;",
							"const appTransId = pm.collectionVariables.get('zaloPayAppTransId') || '260525_txn_test';",
							"const key2 = 'kLtgPl8HHhfvMuDHPwKfgfsY4Ydm9eIz';",
							"",
							"// Build callback data",
							"const callbackData = {",
							"    app_id: appId,",
							"    app_trans_id: appTransId,",
							"    app_time: Date.now(),",
							"    app_user: pm.collectionVariables.get('customerId') || 'CUST-001',",
							"    amount: 50000,",
							"    embed_data: JSON.stringify({",
							"        transactionId: pm.collectionVariables.get('transactionId'),",
							"        bookingId: pm.collectionVariables.get('bookingId'),",
							"        customerId: pm.collectionVariables.get('customerId')",
							"    }),",
							"    item: JSON.stringify([{",
							"        itemid: pm.collectionVariables.get('bookingId'),",
							"        itemname: 'CAB booking',",
							"        itemprice: 50000,",
							"        itemquantity: 1",
							"    }]),",
							"    zp_trans_id: Math.floor(Math.random() * 1000000000),",
							"    server_time: Date.now(),",
							"    channel: 0,",
							"    merchant_user_id: pm.collectionVariables.get('customerId') || 'CUST-001'",
							"};",
							"",
							"// Generate MAC using HMAC SHA256",
							"const dataString = JSON.stringify(callbackData);",
							"",
							"// For Postman, we'll use a pre-computed MAC or skip signature in sandbox",
							"// In production, ZaloPay generates this signature server-side",
							"pm.collectionVariables.set('callbackData', dataString);",
							"pm.collectionVariables.set('callbackAppTransId', appTransId);",
							"",
							"console.log('Callback data prepared:', callbackData);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "test-token",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"type\": \"offer\",\n    \"data\": \"{{callbackData}}\",\n    \"mac\": \"pre_computed_mac_in_production\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/payments/zalopay/callback",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"payments",
						"zalopay",
						"callback"
					]
				},
				"description": "ZaloPay webhook callback endpoint. In production, ZaloPay server calls this endpoint after successful payment.\n\n**For Sandbox Testing:**\n1. This endpoint simulates the callback from ZaloPay\n2. The callback contains payment confirmation data\n3. Signature verification uses Key2\n\n**Note:** In a real scenario, ZaloPay sends the callback directly. For testing, you can:\n1. Use ZaloPay Sandbox portal to simulate payment\n2. Or manually call this endpoint with valid data"
			},
			"response": []
		},
