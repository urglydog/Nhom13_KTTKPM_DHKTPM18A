        "header": [],
        "url": {
          "raw": "{{vnpay_pay_url}}",
          "host": [
            "{{vnpay_pay_url}}"
          ]
        },
        "description": "Postman may not render the VNPay checkout page well. Prefer copying vnpay_pay_url and opening it in Chrome/Edge."
      },
      "response": []
