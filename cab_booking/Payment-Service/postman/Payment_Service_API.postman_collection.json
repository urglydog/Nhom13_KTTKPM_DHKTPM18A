    {
      "name": "VNPay - 1. Tao payment URL (Co JWT)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now();",
              "pm.collectionVariables.set('vnpay_booking_id', `B-VNPAY-${suffix}`);",
              "pm.collectionVariables.set('vnpay_idempotency_key', `idem-vnpay-${suffix}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Charge request returns 2xx', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "const body = pm.response.json();",
              "const result = body.result || body.data || body;",
              "",
              "if (result.transactionId) {",
              "    pm.collectionVariables.set('transaction_id', result.transactionId);",
              "}",
              "if (result.transactionRef) {",
              "    pm.collectionVariables.set('vnpay_transaction_ref', result.transactionRef);",
              "}",
              "if (result.payUrl) {",
              "    pm.collectionVariables.set('vnpay_pay_url', result.payUrl);",
              "    console.log('Open this VNPay URL in browser:', result.payUrl);",
              "}",
              "",
              "pm.test('VNPay payUrl is returned', function () {",
              "    pm.expect(result.payUrl, 'payUrl').to.be.a('string').and.include('sandbox.vnpayment.vn');",
              "});",
              "pm.test('Payment is pending before VNPay callback', function () {",
              "    pm.expect(result.status).to.be.oneOf(['PENDING', 'RETRY']);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{jwt_token}}",
              "type": "string"
            }
