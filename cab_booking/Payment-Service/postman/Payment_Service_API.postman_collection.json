{
  "info": {
    "_postman_id": "4b9f3e4b-9c2f-4512-87a1-2d7c58f0c1a1",
    "name": "Payment Service API",
    "description": "Payment Service Postman collection. Flow 1 tests online prepay from booking.created to payment.initiated/payment.completed. Flow 2 tests CASH settlement after ride.finished: driver collected 100% cash, Driver Service deducts 30% platform fee; driver keeps 70%.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Flow 1 - ONLINE prepay: booking.created -> payment.initiated -> payment.completed",
      "description": "Test flow moi cho ATM/vi dien tu. Postman goi Booking Service tao booking VNPAY; Payment Service tu consume booking.created, tao transaction PENDING va link thanh toan, publish payment.initiated. Sau do request VNPay return gia lap callback thanh cong de Payment publish payment.completed. Neu dung MoMo/ZaloPay thi chay tuong tu bang paymentMethod MOMO/ZALOPAY va callback/IPN tu gateway sandbox.",
      "item": [
        {
          "name": "1. Booking - Create VNPAY booking (publishes booking.created)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/bookings",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "bookings"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupLocation\": \"12 Nguyen Van Bao, Go Vap\",\n  \"dropoffLocation\": \"Tan Son Nhat Airport\",\n  \"customerNote\": \"Postman test online prepay flow\",\n  \"pickupCoordinates\": {\n    \"lat\": 10.8221,\n    \"lng\": 106.6885\n  },\n  \"dropoffCoordinates\": {\n    \"lat\": 10.8188,\n    \"lng\": 106.6619\n  },\n  \"vehicleType\": \"CAR4\",\n  \"paymentMethod\": \"VNPAY\",\n  \"estimatedFare\": {{online_payment_amount}},\n  \"promoCode\": \"\",\n  \"idempotencyKey\": \"{{online_booking_idempotency_key}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Tao booking VNPAY. Booking Service se publish topic booking.created. Payment Service consume event nay va tao transaction PENDING/link thanh toan, khong can goi POST /api/payments/charge."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('online_booking_idempotency_key', `booking-online-${suffix}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Booking create returns 2xx', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "const result = body.result || body.data || body;",
                  "const bookingId = result.id || result.bookingId || result.rideId;",
                  "pm.test('Booking id exists', function () { pm.expect(bookingId).to.be.a('string').and.not.empty; });",
                  "pm.collectionVariables.set('online_payment_booking_id', bookingId);",
                  "pm.collectionVariables.set('online_payment_method', result.paymentMethod || 'VNPAY');",
                  "console.log('online_payment_booking_id =', bookingId);",
                  "console.log('Wait 1-3 seconds, then run step 2 so Payment Service has time to consume booking.created.');"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Payment - Verify initiated transaction by bookingId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payments/booking/{{online_payment_booking_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "booking",
                "{{online_payment_booking_id}}"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "description": "Xac nhan Payment Service da tu tao transaction tu booking.created. Ky vong status PENDING va co payUrl/qr/deeplink, tuc la payment.initiated da du dieu kien de app hien man hinh thanh toan."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Payment lookup returns 2xx', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "const result = body.result || body.data || body;",
                  "pm.test('Payment belongs to booking', function () { pm.expect(result.bookingId).to.eql(pm.collectionVariables.get('online_payment_booking_id')); });",
                  "pm.test('Payment is PENDING or already SUCCESS', function () { pm.expect(['PENDING', 'SUCCESS']).to.include(result.status); });",
                  "const payUrl = result.payUrl || result.paymentUrl || result.deeplink || result.deeplinkWallet || result.qrCodeUrl || '';",
                  "pm.collectionVariables.set('online_payment_transaction_id', result.transactionId || '');",
                  "pm.collectionVariables.set('transaction_id', result.transactionId || '');",
                  "pm.collectionVariables.set('vnpay_transaction_ref', result.gatewayTransactionId || result.transactionId || '');",
                  "pm.collectionVariables.set('online_payment_url', payUrl);",
                  "if (result.amount) pm.collectionVariables.set('online_payment_amount', String(result.amount));",
                  "console.log('online_payment_transaction_id =', result.transactionId);",
                  "console.log('online_payment_url =', payUrl);"
                ]
              }
            }
          ]
        },
        {
          "name": "3. VNPay - Open payment URL manually (Copy only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{online_payment_url}}",
              "host": [
                "{{online_payment_url}}"
              ],
              "path": []
            },
            "description": "Khong bat buoc bam Send. Copy collection variable online_payment_url mo tren browser de thanh toan sandbox that. Neu muon gia lap nhanh callback thanh cong, chay step 4."
          },
          "response": []
        },
        {
          "name": "4. VNPay - Simulate successful return callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payments/vnpay/return?vnp_Amount={{vnpay_callback_amount}}&vnp_BankCode=NCB&vnp_BankTranNo={{vnpay_bank_tran_no}}&vnp_CardType=ATM&vnp_OrderInfo=PostmanTest&vnp_PayDate={{vnpay_pay_date}}&vnp_ResponseCode=00&vnp_TmnCode={{vnpay_tmn_code}}&vnp_TransactionNo={{vnpay_transaction_no}}&vnp_TransactionStatus=00&vnp_TxnRef={{vnpay_transaction_ref}}&vnp_SecureHash={{vnpay_callback_hash}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "vnpay",
                "return"
              ],
              "query": [
                {
                  "key": "vnp_Amount",
                  "value": "{{vnpay_callback_amount}}"
                },
                {
                  "key": "vnp_BankCode",
                  "value": "NCB"
                },
                {
                  "key": "vnp_BankTranNo",
                  "value": "{{vnpay_bank_tran_no}}"
                },
                {
                  "key": "vnp_CardType",
                  "value": "ATM"
                },
                {
                  "key": "vnp_OrderInfo",
                  "value": "PostmanTest"
                },
                {
                  "key": "vnp_PayDate",
                  "value": "{{vnpay_pay_date}}"
                },
                {
                  "key": "vnp_ResponseCode",
                  "value": "00"
                },
                {
                  "key": "vnp_TmnCode",
                  "value": "{{vnpay_tmn_code}}"
                },
                {
                  "key": "vnp_TransactionNo",
                  "value": "{{vnpay_transaction_no}}"
                },
                {
                  "key": "vnp_TransactionStatus",
                  "value": "00"
                },
                {
                  "key": "vnp_TxnRef",
                  "value": "{{vnpay_transaction_ref}}"
                },
                {
                  "key": "vnp_SecureHash",
                  "value": "{{vnpay_callback_hash}}"
                }
              ]
            },
            "description": "Gia lap VNPay redirect/callback thanh cong bang chu ky HMAC-SHA512. Chi dung cho VNPAY flow. Sau request nay Payment Service mark SUCCESS va publish payment.completed."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function pad(n) { return String(n).padStart(2, '0'); }",
                  "function formatVnpDate(d) { return d.getFullYear() + pad(d.getMonth()+1) + pad(d.getDate()) + pad(d.getHours()) + pad(d.getMinutes()) + pad(d.getSeconds()); }",
                  "function encodeUs(value) { return encodeURIComponent(value).replace(/%20/g, '+'); }",
                  "function hmacSha512(key, data) { return CryptoJS.HmacSHA512(data, key).toString(CryptoJS.enc.Hex); }",
                  "const amount = Number(pm.collectionVariables.get('online_payment_amount') || 50000);",
                  "const txnRef = pm.collectionVariables.get('vnpay_transaction_ref') || pm.collectionVariables.get('online_payment_transaction_id');",
                  "pm.test('VNPay txn ref exists before callback', function () { pm.expect(txnRef).to.be.a('string').and.not.empty; });",
                  "const payDate = formatVnpDate(new Date());",
                  "const transactionNo = String(Date.now()).slice(-10);",
                  "const bankTranNo = `VNP${transactionNo}`;",
                  "const params = {",
                  "  vnp_Amount: String(Math.round(amount * 100)),",
                  "  vnp_BankCode: 'NCB',",
                  "  vnp_BankTranNo: bankTranNo,",
                  "  vnp_CardType: 'ATM',",
                  "  vnp_OrderInfo: 'PostmanTest',",
                  "  vnp_PayDate: payDate,",
                  "  vnp_ResponseCode: '00',",
                  "  vnp_TmnCode: pm.collectionVariables.get('vnpay_tmn_code'),",
                  "  vnp_TransactionNo: transactionNo,",
                  "  vnp_TransactionStatus: '00',",
                  "  vnp_TxnRef: txnRef",
                  "};",
                  "const hashData = Object.keys(params).sort().filter(k => params[k]).map(k => `${k}=${encodeUs(params[k])}`).join('&');",
                  "const hash = hmacSha512(pm.collectionVariables.get('vnpay_hash_secret'), hashData);",
                  "pm.collectionVariables.set('vnpay_callback_amount', params.vnp_Amount);",
                  "pm.collectionVariables.set('vnpay_pay_date', payDate);",
                  "pm.collectionVariables.set('vnpay_transaction_no', transactionNo);",
                  "pm.collectionVariables.set('vnpay_bank_tran_no', bankTranNo);",
                  "pm.collectionVariables.set('vnpay_callback_hash', hash);",
                  "console.log('VNPay callback hashData =', hashData);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('VNPay callback returns 2xx', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "const result = body.result || body.data || body;",
                  "pm.test('Payment status is SUCCESS', function () { pm.expect(result.status).to.eql('SUCCESS'); });",
                  "pm.collectionVariables.set('transaction_id', result.transactionId || pm.collectionVariables.get('transaction_id'));",
                  "console.log('VNPay callback completed transaction =', result.transactionId);"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Payment - Verify completed transaction by bookingId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payments/booking/{{online_payment_booking_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "booking",
                "{{online_payment_booking_id}}"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "description": "Xac nhan transaction da SUCCESS sau callback. payment.completed se duoc outbox publish de Booking Service doi sang PAID/PAYMENT_CONFIRMED va moi cho matching bat dau."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Payment lookup returns 2xx', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "const result = body.result || body.data || body;",
                  "pm.test('Payment status is SUCCESS', function () { pm.expect(result.status).to.eql('SUCCESS'); });",
                  "pm.test('Payment method is VNPAY', function () { pm.expect(result.paymentMethod).to.eql('VNPAY'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Flow 2 - CASH settlement after ride.finished (driver collected 100%)",
      "description": "Test flow tien mat: khi tai xe ket thuc chuyen va thu 100% tien mat, Payment Service phat payment.completed voi paymentMethod CASH; Driver Service consume va tru 30% phi nen tang khoi totalEarnings. Request charge trong folder nay la smoke test truc tiep cho payment.completed; khi chay full system, event tuong duong se den tu ride.finished.",
      "item": [
        {
          "name": "1. Driver - Upsert/Get test profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{driver_jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"fullName\": \"Postman Payment Event Driver\",\n    \"email\": \"payment-event-driver@example.com\",\n    \"phoneNumber\": \"0900000001\",\n    \"licenseNumber\": \"GPLX-PAYMENT-EVENT\",\n    \"vehicleType\": \"CAR4\",\n    \"vehiclePlate\": \"PAY-12345\",\n    \"vehicleModel\": \"Toyota Vios\",\n    \"vehicleColor\": \"White\",\n    \"serviceArea\": \"Ho Chi Minh City\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{driver_service_url}}/api/drivers/me/profile",
              "host": [
                "{{driver_service_url}}"
              ],
              "path": [
                "api",
                "drivers",
                "me",
                "profile"
              ]
            },
            "description": "Tao/cap nhat DriverProfile cho token tai xe. Test script luu externalUserId vao collection variable driver_id."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Driver profile request returns 2xx', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "const result = body.result || body.data || body;",
                  "pm.test('Driver profile has externalUserId', function () { pm.expect(result.externalUserId).to.be.a('string').and.not.empty; });",
                  "pm.collectionVariables.set('driver_id', result.externalUserId);",
                  "console.log('driver_id =', result.externalUserId);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "2. Driver - Earnings before payment.completed",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{driver_jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{driver_service_url}}/api/drivers/me/earnings/summary",
              "host": [
                "{{driver_service_url}}"
              ],
              "path": [
                "api",
                "drivers",
                "me",
                "earnings",
                "summary"
              ]
            },
            "description": "Luu totalEarnings truoc khi Payment Service phat event."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Earnings before request returns 2xx', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "const result = body.result || body.data || body;",
                  "const total = Number(result.totalEarnings || 0);",
                  "pm.collectionVariables.set('driver_earnings_before', total.toFixed(2));",
                  "console.log('driver_earnings_before =', total);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "3. Payment - CASH settlement emits payment.completed",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-Idempotency-Key",
                "value": "{{payment_event_idempotency_key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"bookingId\": \"{{payment_event_booking_id}}\",\n    \"customerId\": \"{{customer_id}}\",\n    \"driverId\": \"{{driver_id}}\",\n    \"amount\": {{payment_event_amount}},\n    \"paymentMethod\": \"CASH\",\n    \"currency\": \"VND\",\n    \"description\": \"Postman CASH settlement after ride.finished\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/payments/charge",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "charge"
              ]
            },
            "description": "Smoke test cho logic moi sau ride.finished CASH: Payment Service tao transaction SUCCESS va publish payment.completed. Driver Service consume event nay de tru 30% phi nen tang vi tai xe da thu 100% tien mat."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('payment_event_booking_id', `B-EVENT-${suffix}`);",
                  "pm.collectionVariables.set('payment_event_idempotency_key', `idem-event-${suffix}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Payment charge returns 2xx', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "const result = body.result || body.data || body;",
                  "pm.test('Payment status is SUCCESS', function () { pm.expect(result.status).to.eql('SUCCESS'); });",
                  "pm.test('Payment response keeps driverId', function () { pm.expect(result.driverId).to.eql(pm.collectionVariables.get('driver_id')); });",
                  "if (result.transactionId) pm.collectionVariables.set('transaction_id', result.transactionId);",
                  "console.log('Payment transaction_id =', result.transactionId);",
                  "console.log('Wait 1-3 seconds, then run step 4 so Driver Service has time to consume Kafka event.');"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "4. Driver - Earnings after payment.completed",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{driver_jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{driver_service_url}}/api/drivers/me/earnings/summary",
              "host": [
                "{{driver_service_url}}"
              ],
              "path": [
                "api",
                "drivers",
                "me",
                "earnings",
                "summary"
              ]
            },
            "description": "Chay sau step 3 khoang 1-3 giay. Neu totalEarnings giam dung 30% amount thi Driver Service da consume payment.completed va quyet toan tien mat thanh cong."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Earnings after request returns 2xx', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "const result = body.result || body.data || body;",
                  "const before = Number(pm.collectionVariables.get('driver_earnings_before') || 0);",
                  "const amount = Number(pm.collectionVariables.get('payment_event_amount') || 0);",
                  "const expectedDelta = amount * -0.30;",
                  "const after = Number(result.totalEarnings || 0);",
                  "pm.collectionVariables.set('driver_earnings_after', after.toFixed(2));",
                  "console.log('driver_earnings_before =', before);",
                  "console.log('driver_earnings_after =', after);",
                  "console.log('expected delta =', expectedDelta);",
                  "pm.test('Driver earnings decreased by 30% platform fee for CASH payment', function () { pm.expect(after).to.be.closeTo(before + expectedDelta, 0.01); });"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "5. Payment - Verify transaction includes driverId",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payments/txn/{{transaction_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payments",
                "txn",
                "{{transaction_id}}"
              ]
            },
            "description": "Xac nhan PaymentTransaction da luu driverId de event payment.completed co du du lieu cho Driver Service."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Payment lookup returns 2xx', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "const result = body.result || body.data || body;",
                  "pm.test('Transaction has driverId', function () { pm.expect(result.driverId).to.eql(pm.collectionVariables.get('driver_id')); });"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Thanh toan ZaloPay (Co JWT)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{jwt_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "X-Idempotency-Key",
            "value": "{{$guid}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
