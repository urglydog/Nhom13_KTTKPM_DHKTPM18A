{
	"info": {
		"_postman_id": "payment-service-api",
		"name": "CAB Booking - Payment Service API",
		"description": "Postman collection để test Payment Service API (MoMo Payment Gateway). Bao gồm charge, IPN webhook và truy vấn trạng thái.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8088",
			"type": "string"
		},
		{
			"key": "ngrokUrl",
			"value": "https://your-ngrok-id.ngrok-free.app",
			"type": "string"
		},
		{
			"key": "lastTransactionId",
			"value": "",
			"type": "string"
		},
		{
			"key": "lastBookingId",
			"value": "",
			"type": "string"
		},
		{
			"key": "momoSecretKey",
			"value": "SetA5RDnLHvt51AULf51DyauxUo3kDU6",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Create MoMo Payment (Charge API)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
							"pm.test('Response has data', function () {",
							"    var d = pm.response.json();",
							"    pm.expect(d).to.have.property('result');",
							"});",
							"pm.test('Payment created (SUCCESS or PENDING)', function () {",
							"    var d = pm.response.json().result;",
							"    var validStatuses = ['SUCCESS', 'PENDING'];",
							"    pm.expect(validStatuses).to.include(d.status);",
							"});",
							"pm.test('Store transactionId and bookingId', function () {",
							"    var d = pm.response.json().result;",
							"    if (d.transactionId) pm.collectionVariables.set('lastTransactionId', d.transactionId);",
							"    if (d.bookingId) pm.collectionVariables.set('lastBookingId', d.bookingId);",
							"    console.log('Transaction ID:', d.transactionId);",
							"    console.log('Booking ID:', d.bookingId);",
							"    console.log('Status:', d.status);",
							"    console.log('PayUrl:', d.payUrl);",
							"});",
							"",
							"// Auto-open MoMo pay URL if available",
							"var payUrl = pm.response.json().result && pm.response.json().result.payUrl;",
							"if (payUrl) {",
							"    console.log('\\n=== MoMo Pay URL ===');",
							"    console.log(payUrl);",
							"    console.log('Open this URL in browser to complete payment...');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "X-Idempotency-Key",
						"value": "{{$guid}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"bookingId\": \"B{{$timestamp}}\",\n    \"customerId\": \"C001\",\n    \"amount\": 50000,\n    \"currency\": \"VND\",\n    \"paymentMethod\": \"MOMO\",\n    \"description\": \"Thanh toan chuyen xe CAB Booking B{{$timestamp}}\",\n    \"idempotencyKey\": \"idem-{{$guid}}\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/payments/charge",
					"host": ["{{baseUrl}}"],
					"path": ["api", "payments", "charge"]
				}
			}
		},
		{
			"name": "2. MoMo Webhook Simulator (IPN Success)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
							"pm.test('resultCode = 0', function () {",
							"    var d = pm.response.json();",
							"    pm.expect(d.resultCode).to.eql(0);",
							"});",
							"pm.test('Message is success', function () {",
							"    var d = pm.response.json();",
							"    pm.expect(d.message).to.include(' Successful');",
							"});",
							"console.log('IPN Response:', pm.response.json());"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// MoMo IPN signature calculation",
							"// Format: accessKey={val}&amount={val}&extraData={val}&orderId={val}&orderInfo={val}&partnerCode={val}&requestId={val}&resultCode={val}",
							"",
							"var accessKey = 'MTCKt9W3eU1m39TW';",
							"var amount = pm.variables.replaceIn('{{amount}}') || '50000';",
							"var extraData = pm.variables.replaceIn('{{extraData}}') || '';",
							"var orderId = pm.variables.replaceIn('{{orderId}}') || 'txn_test';",
							"var orderInfo = pm.variables.replaceIn('{{orderInfo}}') || 'Test';",
							"var partnerCode = 'MOMOLRJZ20181206';",
							"var requestId = pm.variables.replaceIn('{{requestId}}') || 'req_test';",
							"var resultCode = pm.variables.replaceIn('{{resultCode}}') || '0';",
							"",
							"var rawData = accessKey + '=' + amount",
							"    + '&extraData=' + extraData",
							"    + '&orderId=' + orderId",
							"    + '&orderInfo=' + orderInfo",
							"    + '&partnerCode=' + partnerCode",
							"    + '&requestId=' + requestId",
							"    + '&resultCode=' + resultCode;",
							"",
							"console.log('Raw signature data:', rawData);",
							"console.log('Note: Signature must be HMAC-SHA256 hex of rawData using secret key');",
							"console.log('Use https://www.labnol.org/code/25927-hmac-sha256-generator to test');",
							"",
							"// Set orderId from previous charge if available",
							"var lastTxnId = pm.collectionVariables.get('lastTransactionId');",
							"if (lastTxnId) {",
							"    pm.variables.set('orderId', lastTxnId);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"partnerCode\": \"MOMOLRJZ20181206\",\n    \"orderId\": \"{{orderId}}\",\n    \"requestId\": \"req_{{timestamp}}\",\n    \"amount\": 50000,\n    \"orderInfo\": \"Thanh toan chuyen xe CAB\",\n    \"orderType\": \"momo_wallet\",\n    \"transId\": 27082023,\n    \"resultCode\": 0,\n    \"message\": \"Successful.\",\n    \"payType\": \"qr\",\n    \"responseTime\": 1693215678910,\n    \"extraData\": \"\",\n    \"signature\": \"CALCULATE_USING_SECRET_KEY\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/payments/momo/ipn",
					"host": ["{{baseUrl}}"],
					"path": ["api", "payments", "momo", "ipn"]
				}
			}
		},
		{
			"name": "2b. MoMo IPN Simulator - Failure",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
							"pm.test('resultCode != 0', function () {",
							"    var d = pm.response.json();",
							"    pm.expect(d.resultCode).to.not.eql(0);",
							"});",
							"console.log('IPN Failure Response:', pm.response.json());"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"partnerCode\": \"MOMOLRJZ20181206\",\n    \"orderId\": \"{{orderId}}\",\n    \"requestId\": \"req_{{timestamp}}\",\n    \"amount\": 50000,\n    \"orderInfo\": \"Thanh toan chuyen xe CAB\",\n    \"orderType\": \"momo_wallet\",\n    \"transId\": 0,\n    \"resultCode\": 1006,\n    \"message\": \"Transaction declined by customer.\",\n    \"payType\": \"qr\",\n    \"responseTime\": 1693215678910,\n    \"extraData\": \"\",\n    \"signature\": \"CALCULATE_USING_SECRET_KEY\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/payments/momo/ipn",
					"host": ["{{baseUrl}}"],
					"path": ["api", "payments", "momo", "ipn"]
				}
			}
		},
		{
			"name": "3. Get Payment by Booking ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
							"pm.test('Has result', function () {",
							"    pm.expect(pm.response.json()).to.have.property('result');",
							"});",
							"pm.test('BookingId matches', function () {",
							"    var bookingId = pm.collectionVariables.get('lastBookingId') || 'B{{$timestamp}}';",
							"    var d = pm.response.json().result;",
							"    if (d.bookingId) pm.expect(d.bookingId).to.eql(bookingId);",
							"});",
							"pm.test('Valid payment status', function () {",
							"    var d = pm.response.json().result;",
							"    var validStatuses = ['SUCCESS', 'PENDING', 'FAILED', 'FAILED_FINAL', 'RETRY', 'INIT'];",
							"    pm.expect(validStatuses).to.include(d.status);",
							"});",
							"pm.test('Print payment details', function () {",
							"    var d = pm.response.json().result;",
							"    console.log('Transaction:', JSON.stringify(d, null, 2));",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/payments/booking/{{lastBookingId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "payments", "booking", "{{lastBookingId}}"]
				}
			}
		},
		{
			"name": "3b. Get Payment by Transaction ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
							"pm.test('Has result', function () {",
							"    pm.expect(pm.response.json()).to.have.property('result');",
							"});",
							"pm.test('Print payment details', function () {",
							"    var d = pm.response.json().result;",
							"    console.log('Transaction:', JSON.stringify(d, null, 2));",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/payments/txn/{{lastTransactionId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "payments", "txn", "{{lastTransactionId}}"]
				}
			}
		},
		{
			"name": "4. Idempotency Test - Duplicate Charge",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
							"pm.test('Same transaction returned (idempotent)', function () {",
							"    var d = pm.response.json().result;",
							"    var lastTxnId = pm.collectionVariables.get('lastTransactionId');",
							"    if (lastTxnId) pm.expect(d.transactionId).to.eql(lastTxnId);",
							"});",
							"console.log('Idempotency check: Same transaction returned.');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "X-Idempotency-Key",
						"value": "idem-{{$guid}}",
						"type": "text",
						"disabled": true
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"bookingId\": \"B{{$timestamp}}\",\n    \"customerId\": \"C001\",\n    \"amount\": 50000,\n    \"currency\": \"VND\",\n    \"paymentMethod\": \"MOMO\",\n    \"description\": \"Thanh toan chuyen xe CAB\",\n    \"idempotencyKey\": \"idem-reuse-key-001\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/payments/charge",
					"host": ["{{baseUrl}}"],
					"path": ["api", "payments", "charge"]
				}
			}
		},
		{
			"name": "5. Validation Test - Missing Required Fields",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 400 or 422', function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([400, 422]);",
							"});",
							"pm.test('Validation error', function () {",
							"    var d = pm.response.json();",
							"    console.log('Validation response:', JSON.stringify(d, null, 2));",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"bookingId\": \"\",\n    \"amount\": 500,\n    \"paymentMethod\": \"MOMO\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/payments/charge",
					"host": ["{{baseUrl}}"],
					"path": ["api", "payments", "charge"]
				}
			}
		},
		{
			"name": "6. Payment with CASH Method",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
							"pm.test('Payment SUCCESS immediately (CASH is sync)', function () {",
							"    var d = pm.response.json().result;",
							"    pm.expect(d.status).to.eql('SUCCESS');",
							"});",
							"pm.test('Store bookingId for query', function () {",
							"    var d = pm.response.json().result;",
							"    if (d.bookingId) {",
							"        pm.collectionVariables.set('lastBookingId', d.bookingId);",
							"        pm.collectionVariables.set('lastTransactionId', d.transactionId);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "X-Idempotency-Key",
						"value": "{{$guid}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"bookingId\": \"B_CASH_{{timestamp}}\",\n    \"customerId\": \"C001\",\n    \"amount\": 30000,\n    \"currency\": \"VND\",\n    \"paymentMethod\": \"CASH\",\n    \"description\": \"Thanh toan tien mat\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/payments/charge",
					"host": ["{{baseUrl}}"],
					"path": ["api", "payments", "charge"]
				}
			}
		},
		{
			"name": "Reference - MoMo Signature Calculator",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// =========================================",
							"// MoMo IPN Signature Calculation Reference",
							"// =========================================",
							"//",
							"// Signature raw data format (IPN):",
							"// accessKey={accessKey}&amount={amount}&extraData={extraData}&orderId={orderId}&orderInfo={orderInfo}&partnerCode={partnerCode}&requestId={requestId}&resultCode={resultCode}",
							"//",
							"// Algorithm: HMAC-SHA256 (hex output)",
							"// Secret key: SetA5RDnLHvt51AULf51DyauxUo3kDU6 (sandbox)",
							"//",
							"// Example calculation:",
							"// raw = 'MTCKt9W3eU1m39TW&50000&&txn_test&Thanh toan&FINTECH&req_test&0'",
							"// signature = HMAC-SHA256(raw, 'SetA5RDnLHvt51AULf51DyauxUo3kDU6')",
							"//",
							"// Test online:",
							"// https://www.labnol.org/code/25927-hmac-sha256-generator",
							"// https://codebeautify.org/hmac-generator",
							"",
							"console.log('MoMo Signature Calculator Reference:');",
							"console.log('1. Build raw signature string');",
							"console.log('2. Compute HMAC-SHA256 with secret key');",
							"console.log('3. Convert to hex string (NOT Base64)');",
							"console.log('4. Set signature field in IPN request');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/payments/charge",
					"host": ["{{baseUrl}}"],
					"path": ["api", "payments", "charge"]
				},
				"description": "This request serves as documentation. No actual API call needed. See test script for signature reference."
			}
		}
	]
}
