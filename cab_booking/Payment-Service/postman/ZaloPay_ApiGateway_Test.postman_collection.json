{
  "info": {
    "_postman_id": "zlp-api-gateway-test",
    "name": "ZaloPay via API Gateway",
    "description": "Collection test ZaloPay payment flow thông qua API Gateway (port 8090). Bao gồm: tạo thanh toán, callback webhook, tra cứu giao dịch, hoàn tiền.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:8090",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "paste_your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "booking_id",
      "value": "BK-10001",
      "type": "string"
    },
    {
      "key": "customer_id",
      "value": "CUST-001",
      "type": "string"
    },
    {
      "key": "transaction_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "zp_trans_id",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Tạo thanh toán ZaloPay",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    var jsonData = pm.response.json();",
              "    console.log('Response:', JSON.stringify(jsonData, null, 2));",
              "",
              "    if (jsonData.data && jsonData.data.transactionId) {",
              "        pm.collectionVariables.set('transaction_id', jsonData.data.transactionId);",
              "    }",
              "    if (jsonData.data && jsonData.data.orderId) {",
              "        pm.collectionVariables.set('order_id', jsonData.data.orderId);",
              "    }",
              "",
              "    pm.test('Status là PENDING hoặc OPEN', function () {",
              "        var status = jsonData.data ? jsonData.data.status : '';",
              "        pm.expect(['PENDING', 'OPEN', 'PENDING_PAYMENT']).to.include(status);",
              "    });",
              "",
              "    pm.test('Có paymentUrl (redirect ZaloPay)', function () {",
              "        pm.expect(jsonData.data).to.have.property('paymentUrl');",
              "    });",
              "}",
              ""
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "X-Idempotency-Key",
            "value": "{{$guid}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"bookingId\": \"{{booking_id}}\",\n    \"customerId\": \"{{customer_id}}\",\n    \"amount\": 50000,\n    \"paymentMethod\": \"ZALOPAY\",\n    \"currency\": \"VND\",\n    \"description\": \"Thanh toan cab booking qua ZaloPay\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{gateway_url}}/api/payments/charge",
          "host": ["{{gateway_url}}"],
          "path": ["api", "payments", "charge"]
        }
      },
      "response": []
    },
    {
      "name": "2. Tra cứu giao dịch theo transactionId",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('Transaction detail:', JSON.stringify(jsonData, null, 2));",
              "",
              "    pm.test('Có trường transactionId', function () {",
              "        pm.expect(jsonData.data).to.have.property('transactionId');",
              "    });",
              "",
              "    pm.test('Có trường status', function () {",
              "        pm.expect(jsonData.data).to.have.property('status');",
              "    });",
              "}",
              ""
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{gateway_url}}/api/payments/txn/{{transaction_id}}",
          "host": ["{{gateway_url}}"],
          "path": ["api", "payments", "txn", "{{transaction_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "3. Tra cứu giao dịch theo orderId",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('Order detail:', JSON.stringify(jsonData, null, 2));",
              "",
              "    pm.test('Có trường orderId', function () {",
              "        pm.expect(jsonData.data).to.have.property('orderId');",
              "    });",
              "}",
              ""
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{gateway_url}}/api/payments/order/{{order_id}}",
          "host": ["{{gateway_url}}"],
          "path": ["api", "payments", "order", "{{order_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "4. ZaloPay Callback Webhook",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var jsonData = pm.response.json();",
              "console.log('Callback response:', JSON.stringify(jsonData, null, 2));",
              "",
              "pm.test('Webhook trả về return_code', function () {",
              "    pm.expect(jsonData).to.have.property('return_code');",
              "});",
              ""
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"data\": \"{\\\"order_id\\\":\\\"{{order_id}}\\\",\\\"zp_trans_id\\\":123456789,\\\"amount\\\":50000,\\\"status\\\":1}\",\n    \"mac\": \"mock_mac_value_replace_with_real\",\n    \"type\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{gateway_url}}/api/payments/zalopay/callback",
          "host": ["{{gateway_url}}"],
          "path": ["api", "payments", "zalopay", "callback"]
        }
      },
      "response": []
    },
    {
      "name": "5. Danh sách giao dịch (GET /api/payments)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('Payment list:', JSON.stringify(jsonData, null, 2));",
              "",
              "    pm.test('Response có data array', function () {",
              "        pm.expect(jsonData.data).to.be.an('array');",
              "    });",
              "}",
              ""
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{gateway_url}}/api/payments",
          "host": ["{{gateway_url}}"],
          "path": ["api", "payments"]
        }
      },
      "response": []
    },
    {
      "name": "6. Hoàn tiền (Refund)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    var jsonData = pm.response.json();",
              "    console.log('Refund response:', JSON.stringify(jsonData, null, 2));",
              "",
              "    pm.test('Refund trả về return_code', function () {",
              "        pm.expect(jsonData).to.have.property('return_code');",
              "    });",
              "}",
              ""
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"transactionId\": \"{{transaction_id}}\",\n    \"amount\": 50000,\n    \"reason\": \"Customer requested cancellation\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{gateway_url}}/api/payments/refund",
          "host": ["{{gateway_url}}"],
          "path": ["api", "payments", "refund"]
        }
      },
      "response": []
    },
    {
      "name": "7. Đối soát ZaloPay",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('Reconcile response:', JSON.stringify(jsonData, null, 2));",
              "",
              "    pm.test('Có trường return_code', function () {",
              "        pm.expect(jsonData).to.have.property('return_code');",
              "    });",
              "}",
              ""
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"start_date\": \"20260101\",\n    \"end_date\": \"20260130\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{gateway_url}}/api/payments/zalopay/reconcile",
          "host": ["{{gateway_url}}"],
          "path": ["api", "payments", "zalopay", "reconcile"]
        }
      },
      "response": []
    },
    {
      "name": "8. Rút tiền ZaloPay",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('Withdraw response:', JSON.stringify(jsonData, null, 2));",
              "",
              "    pm.test('Có trường return_code', function () {",
              "        pm.expect(jsonData).to.have.property('return_code');",
              "    });",
              "}",
              ""
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"amount\": 100000,\n    \"description\": \"Test withdraw\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{gateway_url}}/api/payments/zalopay/withdraw",
          "host": ["{{gateway_url}}"],
          "path": ["api", "payments", "zalopay", "withdraw"]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Hướng dẫn sử dụng:",
          "// 1. Chạy request số 1 (Tạo thanh toán ZaloPay) - transaction_id và order_id sẽ tự lưu vào biến",
          "// 2. Chạy request số 2, 3 để tra cứu giao dịch",
          "// 3. Dán order_id thực tế vào body request số 4 (Callback) - MAC thực tế cần tính từ ZaloPay backend",
          "// 4. Chạy request số 5 xem danh sách",
          "// 5. Chạy request số 6 để hoàn tiền",
          "",
          "console.log('Gateway URL:', pm.collectionVariables.get('gateway_url'));",
          "console.log('Transaction ID:', pm.collectionVariables.get('transaction_id'));",
          "console.log('Order ID:', pm.collectionVariables.get('order_id'));"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ]
}
