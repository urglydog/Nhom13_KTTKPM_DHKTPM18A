{
  "info": {
    "name": "Cab Booking - Full Flow Test",
    "description": "Postman collection test luồng: Đăng ký (3 bước OTP) → Đăng nhập → Tài xế online → Đặt xe → Matching thành công. Tất cả request đi qua API Gateway (port 8080).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variables": [
    {
      "key": "gateway_baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "auth_baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "driverAccessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "passengerAccessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "driverUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "passengerUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "bookingId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{passengerAccessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Registration (via Gateway)",
      "item": [
        {
          "name": "1.1 - Request OTP (Driver)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('OTP sent to email', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.result?.email).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('Response wraps in ApiResponse', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('result');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/auth/register/request-otp",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["auth", "register", "request-otp"]
            },
            "description": "Bước 1/3: Gửi yêu cầu OTP đến email của tài xế. OTP 6 chữ số sẽ được gửi qua email (Brevo).",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"driver_test_{{timestamp}}@gmail.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "1.2 - Verify OTP (Driver)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Email verified', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.result?.verified).to.equal(true);",
                  "    pm.expect(jsonData.result?.canRegister).to.equal(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/auth/register/verify-otp",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["auth", "register", "verify-otp"]
            },
            "description": "Bước 2/3: Xác thực OTP 6 chữ số. Sau bước này email được đánh dấu verified=true, cho phép đăng ký.",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"driver_test_{{timestamp}}@gmail.com\",\n    \"otpCode\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "1.3 - Complete Registration (Driver)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('driverAccessToken', jsonData.result?.accessToken);",
                  "    const userId = jsonData.result?.user?.userId || jsonData.result?.user?.id;",
                  "    pm.collectionVariables.set('driverUserId', userId);",
                  "}",
                  "",
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Registration returns tokens', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.result?.accessToken).to.be.a('string');",
                  "    pm.expect(jsonData.result?.refreshToken).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/auth/register",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Bước 3/3: Hoàn tất đăng ký tài xế. Tạo tài khoản với role='DRIVER', deviceId và platform.",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"fullName\": \"Nguyen Van Driver\",\n    \"email\": \"driver_test_{{timestamp}}@gmail.com\",\n    \"password\": \"Driver@123456\",\n    \"phoneNumber\": \"+84912345601\",\n    \"role\": \"DRIVER\",\n    \"deviceId\": \"driver-device-{{timestamp}}\",\n    \"platform\": \"android\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "1.4 - Request OTP (Passenger)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/auth/register/request-otp",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["auth", "register", "request-otp"]
            },
            "description": "Bước 1/3: Gửi OTP đến email hành khách.",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"passenger_test_{{timestamp}}@gmail.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "1.5 - Verify OTP (Passenger)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/auth/register/verify-otp",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["auth", "register", "verify-otp"]
            },
            "description": "Bước 2/3: Xác thực OTP hành khách.",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"passenger_test_{{timestamp}}@gmail.com\",\n    \"otpCode\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "1.6 - Complete Registration (Passenger)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('passengerAccessToken', jsonData.result?.accessToken);",
                  "    const userId = jsonData.result?.user?.userId || jsonData.result?.user?.id;",
                  "    pm.collectionVariables.set('passengerUserId', userId);",
                  "}",
                  "",
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Registration returns tokens', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.result?.accessToken).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/auth/register",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Bước 3/3: Hoàn tất đăng ký hành khách. Role='CUSTOMER'.",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"fullName\": \"Tran Thi Passenger\",\n    \"email\": \"passenger_test_{{timestamp}}@gmail.com\",\n    \"password\": \"Passenger@123456\",\n    \"phoneNumber\": \"+84912345602\",\n    \"role\": \"CUSTOMER\",\n    \"deviceId\": \"passenger-device-{{timestamp}}\",\n    \"platform\": \"ios\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
