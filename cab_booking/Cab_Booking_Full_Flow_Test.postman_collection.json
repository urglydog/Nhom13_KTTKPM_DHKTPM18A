    {
      "name": "4. Book Ride (Passenger)",
      "item": [
        {
          "name": "4.1 - Create BOOKING (create ride)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    const bookingId = jsonData.result?.bookingId || jsonData.result?.id;",
                  "    pm.collectionVariables.set('bookingId', bookingId);",
                  "}",
                  "",
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Booking created with rideCode or bookingId', function () {",
                  "    const jsonData = pm.response.json();",
                  "    const hasId = !!(jsonData.result?.bookingId || jsonData.result?.id);",
                  "    pm.expect(hasId).to.equal(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{passengerAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/booking/api/v1/bookings",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["booking", "api", "v1", "bookings"]
            },
            "description": "Hành khách tạo yêu cầu đặt xe. Hệ thống (Kafka) sẽ tự động tìm tài xế phù hợp. JWT token chứa customerId từ auth-service.",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"pickupLocation\": \"123 Nguyen Hue, District 1, Ho Chi Minh City\",\n    \"dropoffLocation\": \"456 Le Duan, Go Vap, Ho Chi Minh City\",\n    \"pickupCoordinates\": {\n        \"latitude\": 10.762917,\n        \"longitude\": 106.660172\n    },\n    \"dropoffCoordinates\": {\n        \"latitude\": 10.791919,\n        \"longitude\": 106.699154\n    },\n    \"vehicleType\": \"SEDAN\",\n    \"paymentMethod\": \"CASH\",\n    \"customerNote\": \"Xin chào, tôi cần đặt xe\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "4.2 - Get ACTIVE booking (passenger)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Active booking retrieved', function () {",
                  "    const jsonData = pm.response.json();",
                  "    const result = jsonData.result;",
                  "    if (result) {",
                  "        pm.expect(result).to.have.property('bookingId') || pm.expect(result).to.have.property('id');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{passengerAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/booking/api/v1/bookings/customer/{{passengerUserId}}/active",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["booking", "api", "v1", "bookings", "customer", "{{passengerUserId}}", "active"]
            },
            "description": "Lấy booking đang active (chờ tài xế) của hành khách. Kiểm tra trạng thái: PENDING, SEARCHING, hoặc ASSIGNED."
          }
        },
        {
          "name": "4.3 - Cancel BOOKING (if needed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{passengerAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/booking/api/v1/bookings/{{bookingId}}/cancel",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["booking", "api", "v1", "bookings", "{{bookingId}}", "cancel"]
            },
            "description": "Hủy booking. Chạy request này chỉ khi muốn hủy chuyến (không bắt buộc trong luồng matching thành công)."
          }
        }
      ]
    },
    {
      "name": "5. Driver Handle Assignment & Ride",
      "item": [
        {
          "name": "5.1 - Driver get CURRENT RIDE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
