    {
      "name": "3. Driver Online",
      "item": [
        {
          "name": "3.1 - Driver upsert PROFILE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Profile saved', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('result');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{driverAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/api/drivers/me/profile",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["api", "drivers", "me", "profile"]
            },
            "description": "Tạo/cập nhật profile tài xế (licensePlate, vehicleType). Cần token DRIVER.",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"licensePlate\": \"51A-12345\",\n    \"vehicleType\": \"SEDAN\",\n    \"vehicleModel\": \"Toyota Camry 2023\",\n    \"vehicleColor\": \"Trắng\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "3.2 - Driver go ONLINE (set AVAILABLE)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Driver availability updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('result');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{driverAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{gateway_baseUrl}}/api/drivers/me/availability",
              "host": ["{{gateway_baseUrl}}"],
              "path": ["api", "drivers", "me", "availability"]
            },
            "description": "Cập nhật trạng thái tài xế thành AVAILABLE. Tài xế sẵn sàng nhận chuyến. Gửi kèm vị trí GPS hiện tại.",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"availabilityStatus\": \"AVAILABLE\",\n    \"currentLatitude\": 10.762917,\n    \"currentLongitude\": 106.660172\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "3.3 - Driver get PROFILE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Profile fetched', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('result');",
