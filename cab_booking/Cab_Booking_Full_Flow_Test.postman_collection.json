              "raw": "{\n    \"email\": \"driver_test_{{timestamp}}@gmail.com\",\n    \"password\": \"Driver@123456\",\n    \"deviceId\": \"driver-device-{{timestamp}}\",\n    \"platform\": \"android\"\n}",
              "options": {
