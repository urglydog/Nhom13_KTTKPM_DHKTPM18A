  "item": [
    {
      "name": "1. Customer Registration Flow",
      "item": [
        {
          "name": "1.1 Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.result) {",
                  "  pm.collectionVariables.set('customerAccessToken', jsonData.result.accessToken || '');",
                  "  pm.collectionVariables.set('customerRefreshToken', jsonData.result.refreshToken || '');",
                  "  pm.collectionVariables.set('customerUserId', jsonData.result.user?.userId || jsonData.result.user?.id || '');",
                  "  pm.collectionVariables.set('customerEmail', jsonData.result.user?.email || pm.collectionVariables.get('customerEmail'));",
                  "}",
                  "pm.test('Customer register ok', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Tai Demo Customer\",\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"role\": \"USER\",\n  \"phoneNumber\": \"0901234567\",\n  \"avatarUrl\": \"https://cdn.example.com/avatars/tai-customer.png\",\n  \"deviceId\": \"customer-web-01\",\n  \"platform\": \"WEB\",\n  \"userAgent\": \"Postman Customer\",\n  \"appVersion\": \"1.0.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "1.2 Verify Customer Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{customerAccessToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/verify"
          }
        },
        {
          "name": "1.3 Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.result) {",
                  "  pm.collectionVariables.set('customerAccessToken', jsonData.result.accessToken || '');",
                  "  pm.collectionVariables.set('customerRefreshToken', jsonData.result.refreshToken || '');",
                  "  pm.collectionVariables.set('customerUserId', jsonData.result.user?.userId || jsonData.result.user?.id || '');",
                  "}",
                  "pm.test('Customer login ok', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"deviceId\": \"customer-web-01\",\n  \"platform\": \"WEB\",\n  \"userAgent\": \"Postman Customer\",\n  \"appVersion\": \"1.0.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "1.4 Get My Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me/profile"
          }
        },
        {
          "name": "1.5 Upsert My Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Tai Demo Customer\",\n  \"email\": \"{{customerEmail}}\",\n  \"phoneNumber\": \"0901234567\",\n  \"avatarUrl\": \"https://cdn.example.com/avatars/tai-customer.png\",\n  \"gender\": \"MALE\",\n  \"dateOfBirth\": \"1999-09-09\",\n  \"defaultPickupNote\": \"Cho o cong toa nha Landmark 81\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/users/me/profile"
          }
        },
        {
          "name": "1.6 Get My Account",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me/account"
          }
        },
        {
          "name": "1.7 Register Device",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.result && jsonData.result.id) {",
                  "  pm.collectionVariables.set('customerDeviceId', jsonData.result.id);",
                  "}",
                  "pm.test('Customer device registered', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceIdentifier\": \"customer-device-web-01\",\n  \"deviceName\": \"Chrome on Windows\",\n  \"deviceType\": \"WEB\",\n  \"platform\": \"WEB\",\n  \"osVersion\": \"Windows 11\",\n  \"appVersion\": \"1.0.1\",\n  \"pushToken\": \"push-token-customer\",\n  \"ipAddress\": \"10.10.10.20\",\n  \"userAgent\": \"Postman Customer Browser\",\n  \"trustedSession\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/users/me/devices"
          }
        },
        {
          "name": "1.8 Get My Devices",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me/devices"
          }
        },
        {
          "name": "1.9 Update Device Session",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceName\": \"Tai iPhone 15 PM\",\n  \"deviceType\": \"MOBILE\",\n  \"platform\": \"IOS\",\n  \"osVersion\": \"17.5\",\n  \"appVersion\": \"1.0.1\",\n  \"pushToken\": \"new_push_token_here\",\n  \"ipAddress\": \"10.10.10.21\",\n  \"userAgent\": \"CABBooking/1.0.1 iOS\",\n  \"trustedSession\": true,\n  \"status\": \"ACTIVE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/users/me/devices/{{customerDeviceId}}"
          }
        },
        {
          "name": "1.10 Device Heartbeat",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/users/me/devices/{{customerDeviceId}}/heartbeat"
          }
        },
        {
          "name": "1.11 Revoke Device",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/users/me/devices/{{customerDeviceId}}/revoke"
          }
        }
      ]
    },
