{
  "info": {
    "_postman_id": "f9be1000-8d8f-46fd-a867-1321c40cc73f",
    "name": "CAB Booking - Registration Flows",
    "description": "Collection focused on two validated registration flows: customer and driver. Payloads and routes were aligned to the current auth-service, user-service, driver-service, and gateway config.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
