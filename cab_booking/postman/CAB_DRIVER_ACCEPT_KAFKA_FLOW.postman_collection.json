{
  "info": {
    "_postman_id": "cab-driver-accept-kafka-flow",
    "name": "CAB Driver Accept Kafka Flow",
    "description": "Focused Postman collection for the async driver accept/reject flow. Auth requests use API Gateway because only auth-service is routed through gateway. Driver and Booking requests call service ports directly.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const nonce = Date.now();",
          "if (!pm.collectionVariables.get('customerEmail')) pm.collectionVariables.set('customerEmail', `accept.customer.${nonce}@cab.local`);",
          "if (!pm.collectionVariables.get('driverEmail')) pm.collectionVariables.set('driverEmail', `accept.driver.${nonce}@cab.local`);",
          "if (!pm.collectionVariables.get('idempotencyKey')) pm.collectionVariables.set('idempotencyKey', `accept-flow-${nonce}`);",
          "if (!pm.collectionVariables.get('rejectIdempotencyKey')) pm.collectionVariables.set('rejectIdempotencyKey', `reject-flow-${nonce}`);",
          "if (!pm.collectionVariables.get('estimatedFare')) pm.collectionVariables.set('estimatedFare', '45000');",
          "if (!pm.collectionVariables.get('quoteToken')) pm.collectionVariables.set('quoteToken', 'manual-quote-token');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0. Notes",
      "item": [
        {
          "name": "Flow Notes",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{gatewayUrl}}/gateway/health",
            "description": "Run requests top to bottom. Auth uses {{gatewayUrl}}. Booking and Driver use direct service URLs because only auth-service is routed through gateway in this setup. After Create Booking, wait a few seconds for Matching -> ride.assigned -> Driver consume."
          }
        }
      ]
    },
    {
      "name": "1. Auth Through Gateway",
      "item": [
        {
          "name": "1.1 Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const result = body.result || body;",
                  "pm.collectionVariables.set('customerAccessToken', result.accessToken || pm.collectionVariables.get('customerAccessToken') || '');",
                  "pm.collectionVariables.set('customerUserId', result.user?.userId || result.user?.id || result.userId || pm.collectionVariables.get('customerUserId') || '');",
                  "pm.test('customer registered', () => pm.expect(pm.response.code).to.be.oneOf([200, 201, 409]));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Accept Flow Customer\",\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"phoneNumber\": \"0901000001\",\n  \"avatarUrl\": \"https://example.com/customer.png\",\n  \"role\": \"CUSTOMER\",\n  \"deviceId\": \"accept-flow-customer\",\n  \"platform\": \"WEB\",\n  \"userAgent\": \"Postman Accept Flow\",\n  \"appVersion\": \"1.0.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{gatewayUrl}}/api/auth/register"
          }
        },
        {
          "name": "1.2 Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const result = body.result || body;",
                  "pm.collectionVariables.set('customerAccessToken', result.accessToken || '');",
                  "pm.collectionVariables.set('customerUserId', result.user?.userId || result.user?.id || result.userId || '');",
                  "pm.test('customer logged in', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"deviceId\": \"accept-flow-customer\",\n  \"platform\": \"WEB\",\n  \"userAgent\": \"Postman Accept Flow\",\n  \"appVersion\": \"1.0.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{gatewayUrl}}/api/auth/login"
          }
        },
        {
          "name": "1.3 Register Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const result = body.result || body;",
                  "pm.collectionVariables.set('driverAccessToken', result.accessToken || pm.collectionVariables.get('driverAccessToken') || '');",
                  "pm.collectionVariables.set('driverUserId', result.user?.userId || result.user?.id || result.userId || pm.collectionVariables.get('driverUserId') || '');",
                  "pm.test('driver registered', () => pm.expect(pm.response.code).to.be.oneOf([200, 201, 409]));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Accept Flow Driver\",\n  \"email\": \"{{driverEmail}}\",\n  \"password\": \"{{driverPassword}}\",\n  \"phoneNumber\": \"0902000002\",\n  \"avatarUrl\": \"https://example.com/driver.png\",\n  \"role\": \"DRIVER\",\n  \"deviceId\": \"accept-flow-driver\",\n  \"platform\": \"WEB\",\n  \"userAgent\": \"Postman Accept Flow\",\n  \"appVersion\": \"1.0.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{gatewayUrl}}/api/auth/register"
          }
        },
        {
          "name": "1.4 Login Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const result = body.result || body;",
                  "pm.collectionVariables.set('driverAccessToken', result.accessToken || '');",
                  "pm.collectionVariables.set('driverUserId', result.user?.userId || result.user?.id || result.userId || '');",
                  "pm.test('driver logged in', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{driverEmail}}\",\n  \"password\": \"{{driverPassword}}\",\n  \"deviceId\": \"accept-flow-driver\",\n  \"platform\": \"WEB\",\n  \"userAgent\": \"Postman Accept Flow\",\n  \"appVersion\": \"1.0.0\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{gatewayUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "2. Prepare Driver Direct Service",
      "item": [
        {
          "name": "2.1 Upsert Driver Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{driverAccessToken}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Accept Flow Driver\",\n  \"email\": \"{{driverEmail}}\",\n  \"phoneNumber\": \"0902000002\",\n  \"avatarUrl\": \"https://example.com/driver.png\",\n  \"licenseNumber\": \"GPLX-ACCEPT-FLOW\",\n  \"vehicleType\": \"ECONOMY\",\n  \"vehiclePlate\": \"51H-ACCEPT\",\n  \"vehicleModel\": \"Toyota Vios\",\n  \"vehicleColor\": \"Black\",\n  \"serviceArea\": \"Ho Chi Minh City\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{driverServiceUrl}}/api/drivers/me/profile"
          }
        },
        {
          "name": "2.2 Set Driver ONLINE Near Pickup",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{driverAccessToken}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"availabilityStatus\": \"ONLINE\",\n  \"currentLatitude\": 10.7769,\n  \"currentLongitude\": 106.7009\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{driverServiceUrl}}/api/drivers/me/availability"
          }
        },
        {
          "name": "2.3 Check Internal Availability",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{driverServiceUrl}}/internal/drivers/{{driverUserId}}/availability"
          }
        }
      ]
    },
    {
      "name": "3. Accept Flow",
      "item": [
        {
          "name": "3.1 Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const result = body.result || body;",
                  "pm.collectionVariables.set('bookingId', result.id || pm.collectionVariables.get('bookingId') || '');",
                  "pm.collectionVariables.set('bookingStatus', result.status || '');",
                  "pm.test('booking created', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupLocation\": \"Landmark 81, Binh Thanh, Ho Chi Minh City\",\n  \"dropoffLocation\": \"Ben Thanh Market, District 1, Ho Chi Minh City\",\n  \"customerNote\": \"Accept flow test\",\n  \"pickupCoordinates\": { \"lat\": 10.7769, \"lng\": 106.7009 },\n  \"dropoffCoordinates\": { \"lat\": 10.7626, \"lng\": 106.6602 },\n  \"vehicleType\": \"ECONOMY\",\n  \"paymentMethod\": \"CASH\",\n  \"estimatedFare\": {{estimatedFare}},\n  \"promoCode\": \"ACCEPT\",\n  \"quoteToken\": \"{{quoteToken}}\",\n  \"idempotencyKey\": \"{{idempotencyKey}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{bookingServiceUrl}}/api/v1/bookings"
          }
        },
        {
          "name": "3.2 Poll Driver Current Ride After ride.assigned",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const result = body.result || body;",
                  "pm.collectionVariables.set('driverCurrentRideStatus', result.rideStatus || '');",
                  "pm.test('driver sees assigned ride eventually', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{driverAccessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{driverServiceUrl}}/api/drivers/me/current-ride",
            "description": "Run after a short wait. Expected result.rideId == {{bookingId}} and rideStatus == ASSIGNED once Matching and Driver listener have processed Kafka."
          }
        },
        {
          "name": "3.3 Driver Accept Ride",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const result = body.result || body;",
                  "pm.collectionVariables.set('driverCurrentRideStatus', result.rideStatus || '');",
                  "pm.test('accept request submitted', () => pm.expect(pm.response.code).to.be.oneOf([200, 201, 202]));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{driverAccessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{driverServiceUrl}}/api/drivers/me/rides/{{bookingId}}/accept",
            "description": "Driver Service publishes ride.accept.requested. Booking Service consumes it and publishes ride.accepted."
          }
        },
        {
          "name": "3.4 Poll Booking Active After ride.accepted",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const result = body.result || body;",
                  "pm.collectionVariables.set('bookingStatus', result.status || '');",
                  "pm.test('booking eventually ACCEPTED', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{bookingServiceUrl}}/api/v1/bookings/customer/{{customerUserId}}/active",
            "description": "Run after a short wait. Expected status == ACCEPTED."
          }
        },
        {
          "name": "3.5 Poll Driver Current Ride After ride.accepted",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{driverAccessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{driverServiceUrl}}/api/drivers/me/current-ride",
            "description": "Run after a short wait. Expected rideStatus == ACCEPTED and driverAvailabilityStatus == ON_TRIP."
          }
        }
      ]
    },
    {
      "name": "4. Reject Flow Optional",
      "item": [
        {
          "name": "4.1 Clear Accepted Ride From Driver State",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{driverAccessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fareAmount\": {{estimatedFare}},\n  \"distanceKm\": 5.5,\n  \"completedAt\": \"2026-05-15T12:00:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{driverServiceUrl}}/api/drivers/me/rides/current/complete",
            "description": "Only needed if you ran the accept flow first. It clears Driver Service currentRide so the same driver can be assigned again for the reject flow test."
          }
        },
        {
          "name": "4.2 Set Driver ONLINE Again",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{driverAccessToken}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"availabilityStatus\": \"ONLINE\",\n  \"currentLatitude\": 10.7769,\n  \"currentLongitude\": 106.7009\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{driverServiceUrl}}/api/drivers/me/availability"
          }
        },
        {
          "name": "4.3 Create Booking For Reject",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const result = body.result || body;",
                  "pm.collectionVariables.set('rejectBookingId', result.id || '');",
                  "pm.test('reject booking created', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupLocation\": \"Landmark 81, Binh Thanh, Ho Chi Minh City\",\n  \"dropoffLocation\": \"Saigon Notre Dame Cathedral\",\n  \"customerNote\": \"Reject flow test\",\n  \"pickupCoordinates\": { \"lat\": 10.7769, \"lng\": 106.7009 },\n  \"dropoffCoordinates\": { \"lat\": 10.7798, \"lng\": 106.6990 },\n  \"vehicleType\": \"ECONOMY\",\n  \"paymentMethod\": \"CASH\",\n  \"estimatedFare\": {{estimatedFare}},\n  \"promoCode\": \"REJECT\",\n  \"quoteToken\": \"{{quoteToken}}\",\n  \"idempotencyKey\": \"{{rejectIdempotencyKey}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{bookingServiceUrl}}/api/v1/bookings"
          }
        },
        {
          "name": "4.4 Poll Driver Current Ride After Reject Assignment",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{driverAccessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{driverServiceUrl}}/api/drivers/me/current-ride",
            "description": "Run after a short wait. Expected rideId == {{rejectBookingId}} and rideStatus == ASSIGNED."
          }
        },
        {
          "name": "4.5 Driver Reject Ride",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{driverAccessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{driverServiceUrl}}/api/drivers/me/rides/{{rejectBookingId}}/reject",
            "description": "Driver Service publishes ride.reject.requested. Booking Service consumes it and moves ASSIGNED -> MATCHING."
          }
        },
        {
          "name": "4.6 Poll Booking Active After Reject",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{customerAccessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{bookingServiceUrl}}/api/v1/bookings/customer/{{customerUserId}}/active",
            "description": "Expected status becomes MATCHING, unless Matching immediately assigns again."
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "gatewayUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "driverServiceUrl", "value": "http://localhost:8083", "type": "string" },
    { "key": "bookingServiceUrl", "value": "http://localhost:8084", "type": "string" },
    { "key": "customerEmail", "value": "", "type": "string" },
    { "key": "customerPassword", "value": "12345678", "type": "string" },
    { "key": "customerAccessToken", "value": "", "type": "string" },
    { "key": "customerUserId", "value": "", "type": "string" },
    { "key": "driverEmail", "value": "", "type": "string" },
    { "key": "driverPassword", "value": "12345678", "type": "string" },
    { "key": "driverAccessToken", "value": "", "type": "string" },
    { "key": "driverUserId", "value": "", "type": "string" },
    { "key": "bookingId", "value": "", "type": "string" },
    { "key": "rejectBookingId", "value": "", "type": "string" },
    { "key": "bookingStatus", "value": "", "type": "string" },
    { "key": "driverCurrentRideStatus", "value": "", "type": "string" },
    { "key": "estimatedFare", "value": "45000", "type": "string" },
    { "key": "quoteToken", "value": "manual-quote-token", "type": "string" },
    { "key": "idempotencyKey", "value": "", "type": "string" },
    { "key": "rejectIdempotencyKey", "value": "", "type": "string" }
  ]
}
