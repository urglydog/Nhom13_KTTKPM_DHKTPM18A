		{
			"name": "Pricing API - Calculate Valid Price (5km, demand 1.0)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response status is 200', function() {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Response contains valid pricing structure', function() {",
							"    const response = pm.response.json();",
							"    pm.expect(response).to.have.property('distanceKm');",
							"    pm.expect(response).to.have.property('demandIndex');",
							"    pm.expect(response).to.have.property('baseFare');",
							"    pm.expect(response).to.have.property('distanceFare');",
							"    pm.expect(response).to.have.property('totalFare');",
							"    pm.expect(response).to.have.property('surgeMultiplier');",
							"    pm.expect(response).to.have.property('message');",
							"});",
							"",
							"pm.test('Distance matches request (5km)', function() {",
							"    const response = pm.response.json();",
							"    pm.expect(response.distanceKm).to.eql(5);",
							"});",
							"",
							"pm.test('Demand index matches request (1.0)', function() {",
							"    const response = pm.response.json();",
							"    pm.expect(response.demandIndex).to.eql(1.0);",
							"});",
							"",
							"pm.test('Total fare is greater than base fare', function() {",
							"    const response = pm.response.json();",
							"    const totalFare = parseFloat(response.totalFare);",
							"    const baseFare = parseFloat(response.baseFare);",
							"    pm.expect(totalFare).to.be.above(baseFare);",
							"});",
							"",
							"pm.test('Surge multiplier is >= 1', function() {",
							"    const response = pm.response.json();",
							"    const surge = parseFloat(response.surgeMultiplier);",
							"    pm.expect(surge).to.be.at.least(1.0);",
							"});",
							"",
							"pm.test('Total fare is a positive number', function() {",
							"    const response = pm.response.json();",
							"    pm.expect(response.totalFare).to.be.a('number');",
							"    pm.expect(response.totalFare).to.be.above(0);",
							"});",
							"",
							"pm.test('Base fare is 2.50 (USD)', function() {",
							"    const response = pm.response.json();",
							"    pm.expect(parseFloat(response.baseFare)).to.eql(2.50);",
							"});",
							"",
							"pm.test('Distance fare calculation is correct (5km * 1.50 = 7.50)', function() {",
							"    const response = pm.response.json();",
							"    pm.expect(parseFloat(response.distanceFare)).to.eql(7.50);",
							"});",
							"",
							"pm.test('Pricing calculated successfully message', function() {",
							"    const response = pm.response.json();",
							"    pm.expect(response.message).to.eql('Pricing calculated successfully');",
							"});",
							"",
							"pm.test('Log pricing details for verification', function() {",
							"    const response = pm.response.json();",
							"    console.log('=== Pricing API Test Results ===');",
							"    console.log('Distance:', response.distanceKm, 'km');",
							"    console.log('Demand Index:', response.demandIndex);",
							"    console.log('Base Fare:', response.baseFare, 'USD');",
							"    console.log('Distance Fare:', response.distanceFare, 'USD');",
							"    console.log('Surge Multiplier:', response.surgeMultiplier);",
							"    console.log('Total Fare:', response.totalFare, 'USD');",
							"    console.log('Expected Total: baseFare (2.50) + distanceFare (7.50) = 10.00 USD');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"distanceKm\": 5,\n    \"demandIndex\": 1.0\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/pricing/calculate",
					"host": ["{{baseUrl}}"],
					"path": ["api", "pricing", "calculate"]
				},
				"description": "Test case for Pricing API returning valid price.\n\n## Test Criteria:\n1. HTTP 200 - Success response\n2. Response contains all pricing fields\n3. distanceKm matches request (5)\n4. demandIndex matches request (1.0)\n5. totalFare > baseFare (10.00 > 2.50)\n6. surgeMultiplier >= 1 (should be 1.00)\n7. Total Fare = Base Fare (2.50) + Distance Fare (7.50) = 10.00 USD\n\n## Request Body:\n```json\n{\n    \"distanceKm\": 5,\n    \"demandIndex\": 1.0\n}\n```"
			},
			"response": []
		},
		{
			"name": "Pricing API - Calculate Price with Surge (demand 2.0)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response status is 200', function() {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Surge multiplier is applied (demand 2.0)', function() {",
							"    const response = pm.response.json();",
							"    const surge = parseFloat(response.surgeMultiplier);",
							"    pm.expect(surge).to.be.at.least(1.0);",
							"    // With demand 2.0, surge should be 2.0 (or capped at max 3.0)",
							"    pm.expect(surge).to.be.at.most(3.0);",
							"});",
							"",
							"pm.test('Total fare with surge is higher than without surge', function() {",
							"    const response = pm.response.json();",
							"    const totalFare = parseFloat(response.totalFare);",
							"    // Base without surge for 5km: 2.50 + 7.50 = 10.00",
							"    // With surge 2.0: 10.00 * 2.0 = 20.00",
							"    pm.expect(totalFare).to.be.above(10.00);",
							"});",
							"",
							"pm.test('Log surge pricing details', function() {",
							"    const response = pm.response.json();",
							"    console.log('=== Surge Pricing Test ===');",
							"    console.log('Distance:', response.distanceKm, 'km');",
							"    console.log('Demand Index:', response.demandIndex);",
							"    console.log('Base Fare:', response.baseFare);",
							"    console.log('Distance Fare:', response.distanceFare);",
							"    console.log('Surge Multiplier:', response.surgeMultiplier);",
							"    console.log('Total Fare:', response.totalFare);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"distanceKm\": 5,\n    \"demandIndex\": 2.0\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/pricing/calculate",
					"host": ["{{baseUrl}}"],
					"path": ["api", "pricing", "calculate"]
				},
				"description": "Test Pricing API with surge pricing (demand index 2.0)\n\n## Expected:\n- surgeMultiplier = 2.0\n- Total Fare = (2.50 + 7.50) * 2.0 = 20.00 USD"
			},
			"response": []
		},
