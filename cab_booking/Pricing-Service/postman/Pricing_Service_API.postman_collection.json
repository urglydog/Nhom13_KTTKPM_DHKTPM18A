{
  "info": {
    "name": "Pricing Service API",
    "description": "Postman collection for testing the Pricing Service (Spring Boot microservice on port 8087). Covers all 6 REST endpoints: fare estimate, confirm estimate, surge management, and demand-supply metrics.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8087/api/pricing",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Fare Estimate",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has estimateId', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('estimateId');",
              "    pm.expect(jsonData.estimateId).to.not.be.empty;",
              "    // Store estimateId for confirm request",
              "    pm.collectionVariables.set('estimateId', jsonData.estimateId);",
              "});",
              "",
              "pm.test('Response has required fields', function () {",
              "    var jsonData = pm.response.json();",
              "    var requiredFields = [",
              "        'pickupZone', 'dropoffZone', 'vehicleType',",
              "        'distanceKm', 'durationMinutes',",
              "        'baseFare', 'distanceFare', 'timeFare',",
              "        'surgeMultiplier', 'totalFare', 'currency',",
              "        'expiresAt', 'message'",
              "    ];",
              "    requiredFields.forEach(function(field) {",
              "        pm.expect(jsonData).to.have.property(field);",
              "    });",
              "});",
              "",
              "pm.test('Total fare is calculated correctly', function () {",
              "    var jsonData = pm.response.json();",
              "    var total = parseFloat(jsonData.totalFare);",
              "    var base = parseFloat(jsonData.baseFare);",
              "    var dist = parseFloat(jsonData.distanceFare);",
              "    var time = parseFloat(jsonData.timeFare);",
              "    var surge = parseFloat(jsonData.surgeMultiplier);",
              "    var expected = (base + dist + time) * surge;",
              "    pm.expect(total).to.be.closeTo(expected, 0.01);",
              "});",
              "",
              "pm.test('Currency is USD', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.currency).to.eq('USD');",
              "});",
              "",
              "pm.test('Estimate has not expired yet', function () {",
              "    var jsonData = pm.response.json();",
              "    var expiresAt = new Date(jsonData.expiresAt);",
              "    var now = new Date();",
              "    pm.expect(expiresAt.getTime()).to.be.above(now.getTime());",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/estimate?pickupLat=10.7629&pickupLng=106.6825&dropoffLat=10.8231&dropoffLng=106.6297&vehicleType=ECONOMY&estimatedDurationMinutes=30",
          "host": ["{{baseUrl}}"],
          "path": ["estimate"],
          "query": [
            {
              "key": "pickupLat",
              "value": "10.7629",
              "description": "Pickup latitude (Ho Chi Minh City area)"
            },
            {
              "key": "pickupLng",
              "value": "106.6825",
              "description": "Pickup longitude"
            },
            {
              "key": "dropoffLat",
              "value": "10.8231",
              "description": "Dropoff latitude"
            },
            {
              "key": "dropoffLng",
              "value": "106.6297",
              "description": "Dropoff longitude"
            },
            {
              "key": "vehicleType",
              "value": "ECONOMY",
              "description": "Vehicle type: ECONOMY | COMFORT | PREMIUM",
              "enabled": true
            },
            {
              "key": "estimatedDurationMinutes",
              "value": "30",
              "description": "Optional estimated duration in minutes",
              "enabled": true
            }
          ]
        },
        "description": "Calculate a fare estimate between two locations for a given vehicle type. Returns a detailed breakdown of the fare including base fare, distance fare, time fare, surge multiplier, and total. The estimate expires 15 minutes after creation."
      }
    },
