              "    var jsonData = pm.response.json();",
              "    var pathParts = pm.request.url.split('/');",
              "    var pathEstimateId = pathParts[pathParts.length - 1];",
              "    pm.expect(jsonData.id).to.eq(pathEstimateId);",
              "});"
            ]
          }
        }
