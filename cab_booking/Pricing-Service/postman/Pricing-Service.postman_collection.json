    {
      "name": "01 - External API Smoke",
      "item": [
        {
          "name": "Mapbox Matrix - Distance Duration",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Mapbox responded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 401, 403]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.test('Mapbox has code/distances/durations', function () {",
                  "    pm.expect(json.code).to.exist;",
                  "    pm.expect(json.distances).to.be.an('array');",
                  "    pm.expect(json.durations).to.be.an('array');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.mapbox.com/directions-matrix/v1/mapbox/driving/{{pickup_lng}},{{pickup_lat}};{{dropoff_lng}},{{dropoff_lat}}?annotations=distance,duration&access_token={{MAPBOX_API_KEY}}",
              "protocol": "https",
              "host": [
                "api",
                "mapbox",
                "com"
              ],
              "path": [
                "directions-matrix",
                "v1",
                "mapbox",
                "driving",
                "{{pickup_lng}},{{pickup_lat}};{{dropoff_lng}},{{dropoff_lat}}"
              ],
              "query": [
                {
                  "key": "annotations",
                  "value": "distance,duration"
                },
                {
                  "key": "access_token",
                  "value": "{{MAPBOX_API_KEY}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Open-Meteo - Current Weather",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Open-Meteo responded', function () {",
