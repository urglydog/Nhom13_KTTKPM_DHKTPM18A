        {
          "name": "06 - Estimate Fare And Store Quote Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Fare estimate generated', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.estimateId).to.be.a('string');",
                  "  pm.expect(json.currency).to.eql('VND');",
                  "  pm.expect(Number(json.distanceKm)).to.be.above(0);",
                  "  pm.expect(Number(json.durationMinutes)).to.be.above(0);",
                  "  pm.expect(Number(json.totalFare)).to.be.above(0);",
                  "  pm.expect(json.pricingConfigVersion).to.exist;",
                  "  pm.expect(json.distanceSource).to.be.oneOf(['MAPBOX', 'MAPBOX_CACHE', 'HAVERSINE_FALLBACK']);",
                  "  pm.expect(json.weatherSource).to.be.oneOf(['OPEN_METEO', 'OPEN_METEO_CACHE', 'FALLBACK_UNAVAILABLE']);",
                  "});",
                  "const estimate = pm.response.json();",
                  "pm.collectionVariables.set('estimate_id', estimate.estimateId);",
                  "pm.collectionVariables.set('estimated_fare', estimate.totalFare);",
                  "pm.collectionVariables.set('surge_multiplier', estimate.surgeMultiplier);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/pricing/estimate?pickupLat={{pickup_lat}}&pickupLng={{pickup_lng}}&dropoffLat={{dropoff_lat}}&dropoffLng={{dropoff_lng}}&vehicleType={{vehicle_type}}",
