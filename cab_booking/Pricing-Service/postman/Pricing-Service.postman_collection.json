                "type": "text/javascript",
                "exec": [
                  "pm.test('Config returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.calculation.currency).to.eql('VND');",
                  "  pm.expect(json.surge.defaultMultiplier).to.exist;",
                  "  pm.expect(json.weather.badWeatherAdjustment).to.exist;",
