{
	"info": {
		"_postman_id": "cab-booking-demo-v2",
		"name": "CAB Booking - Sequential Demo Flow",
		"description": "Kịch bản demo tuần tự không dùng mock endpoints.\nThực hiện theo thứ tự Step 1 -> Step 6.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "STEP 0: Lấy Token xác thực (JWT Debug)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    var token = pm.response.text();",
							"    pm.environment.set(\"authToken\", token);",
							"    console.log(\"Authenticated!\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{gatewayUrl}}/auth/token",
					"host": ["{{gatewayUrl}}"],
					"path": ["auth", "token"]
				}
			},
			"response": []
		},
		{
			"name": "STEP 1: Khách hàng Đặt xe (Create Booking)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Booking OK\", function () {",
							"    var res = pm.response.json();",
							"    pm.expect(res.code).to.eql(200);",
							"    pm.environment.set(\"bookingId\", res.result.id);",
							"    console.log(\"Booking ID stored: \", res.result.id);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"pickupLocation\": \"12 Nguyễn Văn Bảo, Gò Vấp\",\n    \"dropoffLocation\": \"Sân bay Tân Sơn Nhất\",\n    \"pickupCoordinates\": { \"lat\": 10.8221, \"lng\": 106.6885 },\n    \"dropoffCoordinates\": { \"lat\": 10.8188, \"lng\": 106.6619 },\n    \"vehicleType\": \"SEDAN\",\n    \"paymentMethod\": \"CASH\",\n    \"estimatedFare\": 80000.0,\n    \"idempotencyKey\": \"{{$guid}}\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/bookings",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "bookings"]
				}
			},
			"response": []
		},
		{
			"name": "STEP 2: Tài xế Tìm chuyến (Nearby Check)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/bookings/nearby?lat=10.8221&lng=106.6885",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "bookings", "nearby"],
					"query": [
						{ "key": "lat", "value": "10.8221" },
						{ "key": "lng", "value": "106.6885" }
					]
				}
			},
			"response": []
		},
		{
			"name": "STEP 3: Tài xế Chấp nhận cuốc (Assign)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Assigned OK\", function () {",
							"    pm.expect(pm.response.json().code).to.eql(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}/assign?driverId={{driverId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "bookings", "{{bookingId}}", "assign"],
					"query": [
						{ "key": "driverId", "value": "{{driverId}}" }
					]
				}
			},
			"response": []
		},
		{
			"name": "STEP 4: Tài xế Đón khách (Start Ride)",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}/start",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "bookings", "{{bookingId}}", "start"]
				}
			},
			"response": []
		},
		{
			"name": "STEP 5: Tài xế Hoàn thành cuốc (Complete Ride)",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}/complete",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "bookings", "{{bookingId}}", "complete"]
				}
			},
			"response": []
		},
		{
			"name": "STEP 6: Khách hàng Đánh giá (Review)",
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"rating\": 5,\n    \"comment\": \"Tuyệt vời, lái xe nhiệt tình.\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}/review",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "bookings", "{{bookingId}}", "review"]
				}
			},
			"response": []
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{authToken}}",
				"type": "string"
			}
		]
	}
}
