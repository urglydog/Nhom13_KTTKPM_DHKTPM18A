    {
      "name": "04 - Booking Create Ride",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const result = json.result || {};",
              "",
              "pm.test('Booking created with correct DTO fields', function () {",
              "    pm.expect(json.code).to.eql(200);",
              "    pm.expect(result.id).to.be.a('string').and.not.empty;",
              "    pm.expect(result.customerId).to.eql(pm.environment.get('user_id'));",
              "    pm.expect(result.status).to.eql('CREATED');",
              "    pm.expect(result.pickupCoordinates.lat).to.eql(10.8221);",
              "    pm.expect(result.dropoffCoordinates.lng).to.eql(106.6619);",
              "});",
              "",
              "pm.environment.set('booking_id', result.id);"
            ]
          }
        }
      ],
