{
  "info": {
    "_postman_id": "cab-booking-level-1-core-flow",
    "name": "CAB-BOOKING LEVEL 1 - CORE FLOW",
    "description": "Level 1 basic API and core flow collection generated from the real Controller/DTO contracts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('run_id')) {",
          "    const runId = Date.now().toString();",
          "    pm.environment.set('run_id', runId);",
          "    pm.environment.set('customer_email', `customer_${runId}@example.com`);",
          "    pm.environment.set('driver_email', `driver_${runId}@example.com`);",
          "    pm.environment.set('customer_device_id', `customer-device-${runId}`);",
          "    pm.environment.set('driver_device_id', `driver-device-${runId}`);",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "auth_base_url",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "booking_base_url",
      "value": "http://localhost:8084",
      "type": "string"
    },
    {
      "key": "driver_base_url",
      "value": "http://localhost:8083",
      "type": "string"
    },
    {
      "key": "pricing_base_url",
      "value": "http://localhost:8088",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Auth Register Customer",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = Date.now().toString();",
              "pm.environment.set('run_id', runId);",
              "pm.environment.set('customer_email', `customer_${runId}@example.com`);",
              "pm.environment.set('driver_email', `driver_${runId}@example.com`);",
              "pm.environment.set('customer_device_id', `customer-device-${runId}`);",
              "pm.environment.set('driver_device_id', `driver-device-${runId}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const result = json.result || {};",
              "const user = result.user || {};",
              "",
              "pm.test('Register returns valid token and user', function () {",
              "    pm.expect(json.code).to.eql(200);",
              "    pm.expect(result.accessToken).to.be.a('string').and.not.empty;",
              "    pm.expect(result.refreshToken).to.be.a('string').and.not.empty;",
              "    pm.expect(user.userId).to.be.a('string').and.not.empty;",
              "    pm.expect(user.role).to.eql('CUSTOMER');",
              "});",
              "",
              "pm.environment.set('access_token', result.accessToken);",
              "pm.environment.set('refresh_token', result.refreshToken);",
              "pm.environment.set('user_id', user.userId);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Level 1 Customer\",\n  \"email\": \"{{customer_email}}\",\n  \"password\": \"Customer@123456\",\n  \"phoneNumber\": \"+84910000001\",\n  \"avatarUrl\": \"https://example.com/avatar/customer.png\",\n  \"role\": \"CUSTOMER\",\n  \"deviceId\": \"{{customer_device_id}}\",\n  \"platform\": \"android\",\n  \"userAgent\": \"Postman Level 1\",\n  \"appVersion\": \"1.0.0\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/auth/register",
          "host": [
            "{{auth_base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 - Auth Login Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const result = json.result || {};",
              "const user = result.user || {};",
              "",
              "pm.test('Login returns valid token and user id', function () {",
              "    pm.expect(json.code).to.eql(200);",
              "    pm.expect(result.accessToken).to.be.a('string').and.not.empty;",
              "    pm.expect(result.tokenType).to.match(/Bearer/i);",
              "    pm.expect(user.userId).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.environment.set('access_token', result.accessToken);",
              "pm.environment.set('refresh_token', result.refreshToken);",
              "pm.environment.set('user_id', user.userId);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{customer_email}}\",\n  \"password\": \"Customer@123456\",\n  \"deviceId\": \"{{customer_device_id}}\",\n  \"platform\": \"android\",\n  \"userAgent\": \"Postman Level 1\",\n  \"appVersion\": \"1.0.0\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/auth/login",
          "host": [
            "{{auth_base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 - Pricing Estimate Fare And ETA",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Pricing returns ETA and fare', function () {",
              "    pm.expect(json.estimateId).to.be.a('string').and.not.empty;",
              "    pm.expect(Number(json.durationMinutes)).to.be.above(0);",
              "    pm.expect(Number(json.distanceKm)).to.be.above(0);",
              "    pm.expect(Number(json.totalFare)).to.be.above(0);",
              "    pm.expect(json.vehicleType).to.eql('ECONOMY');",
              "});",
              "",
              "pm.environment.set('estimate_id', json.estimateId);",
              "pm.environment.set('eta_minutes', json.durationMinutes);",
              "pm.environment.set('distance_km', json.distanceKm);",
              "pm.environment.set('estimated_fare', json.totalFare);"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{pricing_base_url}}/api/pricing/estimate?pickupLat=10.8221&pickupLng=106.6885&dropoffLat=10.8188&dropoffLng=106.6619&vehicleType=ECONOMY&estimatedDurationMinutes=18",
          "host": [
            "{{pricing_base_url}}"
          ],
          "path": [
            "api",
            "pricing",
            "estimate"
          ],
          "query": [
            {
              "key": "pickupLat",
              "value": "10.8221"
            },
            {
              "key": "pickupLng",
              "value": "106.6885"
            },
            {
              "key": "dropoffLat",
              "value": "10.8188"
            },
            {
              "key": "dropoffLng",
              "value": "106.6619"
            },
            {
              "key": "vehicleType",
              "value": "ECONOMY"
            },
            {
              "key": "estimatedDurationMinutes",
              "value": "18"
            }
          ]
        }
