          "mode": "raw",
          "raw": "{\n  \"pickupLocation\": \"12 Nguyen Van Bao, Go Vap\",\n  \"dropoffLocation\": \"Tan Son Nhat Airport\",\n  \"customerNote\": \"Level 1 Postman flow\",\n  \"pickupCoordinates\": {\n    \"lat\": 10.8221,\n    \"lng\": 106.6885\n  },\n  \"dropoffCoordinates\": {\n    \"lat\": 10.8188,\n    \"lng\": 106.6619\n  },\n  \"vehicleType\": \"ECONOMY\",\n  \"paymentMethod\": \"CASH\",\n  \"estimatedFare\": {{estimated_fare}},\n  \"promoCode\": \"\",\n  \"quoteToken\": \"{{estimate_id}}\",\n  \"idempotencyKey\": \"booking-{{run_id}}\"\n}"
        },
