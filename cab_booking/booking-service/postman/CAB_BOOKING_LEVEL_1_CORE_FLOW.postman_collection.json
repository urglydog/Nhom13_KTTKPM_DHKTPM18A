    {
      "name": "05 - Booking Get Customer History",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const page = json.result || {};",
              "const content = page.content || [];",
              "",
              "pm.test('Customer history contains created booking', function () {",
              "    pm.expect(json.code).to.eql(200);",
              "    pm.expect(content).to.be.an('array');",
              "    const bookingId = pm.environment.get('booking_id');",
              "    const found = content.some(item => item.id === bookingId);",
              "    pm.expect(found).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
